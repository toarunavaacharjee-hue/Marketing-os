# App URL
NEXT_PUBLIC_SITE_URL=https://aimarketingworkbench.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional for local development only:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Workspace Anthropic keys (per company) are stored encrypted in Supabase.
# Run supabase/company_ai_keys.sql, then set this (same name/value in Vercel env vars for prod):
# Generate e.g. openssl rand -base64 32 — do not change after keys exist without a migration.
WORKSPACE_AI_KEY_ENCRYPTION_SECRET=long-random-string-do-not-rotate-without-migration

# Platform AI (Starter, Free, Growth when they have no BYOK; Enterprise must BYOK):
ANTHROPIC_API_KEY=sk-ant-...

# Google Analytics 4 (real API)
# Service account with GA4 Viewer/Analyst access to your property
GA4_SERVICE_ACCOUNT_EMAIL=ga4-reader@your-gcp-project.iam.gserviceaccount.com
# Use literal \n for newlines when set in env files or Vercel
GA4_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

