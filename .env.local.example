# App URL
NEXT_PUBLIC_SITE_URL=https://aimarketingworkbench.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional for local development only:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic
# Optional fallback key used by /api/ai/daily-brief when user profile key is not set
ANTHROPIC_API_KEY=sk-ant-...

# Google Analytics 4 (real API)
# Service account with GA4 Viewer/Analyst access to your property
GA4_SERVICE_ACCOUNT_EMAIL=ga4-reader@your-gcp-project.iam.gserviceaccount.com
# Use literal \n for newlines when set in env files or Vercel
GA4_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

